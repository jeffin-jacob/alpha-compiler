type trip: [integer: a; integer: b; integer: c]

type T1: trip -> integer
type T2: integer -> integer

function trimul: T1
function e: T2

trimul as(x, y, z) := {
    return x*y*z;
}

e(x) := {
    [integer: y; integer: z; integer: a]
    y := 2*x;
    z := 3*y;

    a := trimul(x, y, z);
    return a;
}
